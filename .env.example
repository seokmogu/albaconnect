# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/albaconnect
# JWT
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars
JWT_REFRESH_SECRET=change-this-too-different-from-jwt-secret-min-32-chars
# Redis (optional — omit to use in-memory fallback cache)
# REDIS_URL=redis://localhost:6379
# Server
PORT=3001
NODE_ENV=development
WEB_URL=http://localhost:3000
# Next.js (web)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_KAKAO_MAP_API_KEY=your-kakao-map-api-key
# Toss Payments (https://developers.tosspayments.com/)
TOSS_SECRET_KEY=test_sk_...          # Server-side secret key (omit for dev/stub mode)
TOSS_CLIENT_KEY=test_ck_...          # Client-side publishable key (for frontend widget)
TOSS_WEBHOOK_SECRET=your-webhook-secret  # Webhook signing secret (omit to skip validation)
