DATABASE_URL=postgresql://postgres:postgres@localhost:5432/albaconnect
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
KAKAO_REST_API_KEY=your-kakao-rest-api-key
TOSS_CLIENT_KEY=test_ck_your_toss_client_key
TOSS_SECRET_KEY=test_sk_your_toss_secret_key
PORT=3001
NODE_ENV=development

# Web Push (VAPID) — required for PWA background notifications
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BG...
VAPID_PRIVATE_KEY=...
VAPID_EMAIL=mailto:admin@yourdomain.com
