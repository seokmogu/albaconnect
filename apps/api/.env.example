DATABASE_URL=postgresql://postgres:postgres@localhost:5432/albaconnect
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
# KakaoTalk Alim Talk (register templates at https://center-pf.kakao.com before use)
KAKAO_BIZ_API_KEY=<from kakao biz center>
KAKAO_SENDER_KEY=<plusfriend sender key>
TOSS_CLIENT_KEY=test_ck_your_toss_client_key
TOSS_SECRET_KEY=test_sk_your_toss_secret_key
PORT=3001
NODE_ENV=development

# Web Push (VAPID) — required for PWA background notifications
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BG...
VAPID_PRIVATE_KEY=...
VAPID_EMAIL=mailto:admin@yourdomain.com

# Sentry — Error tracking & performance monitoring
# Leave unset in development; set in staging/production
# Get DSN from https://sentry.io → Settings → Projects → Client Keys
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
